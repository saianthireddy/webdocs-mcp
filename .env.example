# All optional - the stack runs with zero configuration.
WEBDOCS_DB_PATH=data/webdocs.duckdb
WEBDOCS_EMBEDDER=hashing          # hashing (offline, default) | openai
# OPENAI_API_KEY=sk-...           # required only when WEBDOCS_EMBEDDER=openai
WEBDOCS_EMBED_DIM=256
WEBDOCS_CHUNK_SIZE=1200
WEBDOCS_CHUNK_OVERLAP=150
WEBDOCS_MAX_PAGES=50
WEBDOCS_MAX_DEPTH=3
